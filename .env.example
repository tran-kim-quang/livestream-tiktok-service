# ── TikTok ────────────────────────────────────────────────────────────────────
TIKTOK_USERNAME=
TIKTOK_LIVE_RETRY_SEC=30

# ── Redis ─────────────────────────────────────────────────────────────────────
# Từ trong container, Redis được truy cập qua Docker network (service name + port nội bộ 6379)
# Nếu chạy trực tiếp (không Docker): redis://127.0.0.1:6380/0
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_KEY=livestream:comments
REDIS_ROOM_MAX_COMMENTS=2000

# ── Service port ──────────────────────────────────────────────────────────────
LIVESTREAM_SERVICE_PORT=8002
